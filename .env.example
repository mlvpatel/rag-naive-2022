# Copy to .env and fill in. For a fully local, keyless run, set the provider
# to ollama and leave the OpenAI key blank.

# Provider: openai (authentic 2022 default) or ollama (local, no cost)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-ada-002
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Generation. Model name selects the provider: gpt* uses OpenAI,
# llama*/qwen*/mistral* uses Ollama.
LLM_MODEL=gpt-3.5-turbo

# Keys (leave OpenAI blank for a local Ollama run)
OPENAI_API_KEY=

# Vector store
CHROMA_DIR=./chroma_db
COLLECTION_NAME=ragflow_documents

# Retrieval (naive: a single dense search, no reranking)
TOP_K=4
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# API. The service binds to loopback and has no auth, so keep the origin narrow
# and put a gateway in front of it before exposing it to a network.
CORS_ORIGINS=http://localhost:8501
MAX_UPLOAD_MB=25
